{
  "name": "deck-ai-assistant",
  "version": "0.0.5",
  "description": "An AI assistant for Steam Deck",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run lint"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lukather/deck-ai-assistant"
  },
  "keywords": [
    "decky",
    "plugin",
    "ai",
    "assistant",
    "steam-deck"
  ],
  "author": "Lorenzo Strambi <mail@lukather.net>",
  "license": "GNU GPL V2",
  "bugs": {
    "url": "https://github.com/lukather/deck-ai-assistant/issues"
  },
  "homepage": "https://github.com/lukather/deck-ai-assistant#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@decky/rollup": "^1.0.1",
    "@decky/ui": "^4.7.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-router": "^5.1.20",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.22.5",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "react-icons": "^4.12.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
